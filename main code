#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>
#include <ESP32Servo.h>
#include <Adafruit_INA219.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// ================= WIFI =================
const char* ssid = "...";
const char* password = "...";

WebServer server(80);

// ================= OLED =================
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64

Adafruit_SSD1306 display(
  SCREEN_WIDTH,
  SCREEN_HEIGHT,
  &Wire,
  -1
);

// ================= INA219 =================
Adafruit_INA219 ina219;

// ================= SERVO =================
Servo trackerServo;

// ================= PIN =================
const int ldrLeftPin  = 34;
const int ldrRightPin = 35;
const int servoPin    = 18;

// ================= TRACKER =================
int servoPos = 90;

const int SERVO_MIN = 0;
const int SERVO_MAX = 180;

const int deadBand = 150;

unsigned long lastMove = 0;
const unsigned long moveInterval = 100;

// ================= WEB DATA =================
int gLeft = 0;
int gRight = 0;
int gServo = 0;

float gVoltage = 0;
float gCurrent = 0;
float gPower = 0;

