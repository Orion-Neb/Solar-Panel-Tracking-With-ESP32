// =====================================================
// JSON DATA
// =====================================================
void handleData()
{
  String json = "{";

  json += "\"left\":" + String(gLeft) + ",";
  json += "\"right\":" + String(gRight) + ",";
  json += "\"servo\":" + String(gServo) + ",";
  json += "\"voltage\":" + String(gVoltage,2) + ",";
  json += "\"current\":" + String(gCurrent,1) + ",";
  json += "\"power\":" + String(gPower,3);

  json += "}";

  server.send(200, "application/json", json);
}

// =====================================================
// LDR AVERAGE
// =====================================================
int readLDR(int pin)
{
  long total = 0;

  for(int i=0;i<10;i++)
  {
    total += analogRead(pin);
    delay(2);
  }

  return total / 10;
}

// =====================================================
// SETUP
// =====================================================
void setup()
{
  Serial.begin(115200);

  analogReadResolution(12);

  Wire.begin(21,22);

  if(!display.begin(SSD1306_SWITCHCAPVCC,0x3C))
  {
    Serial.println("OLED gagal");
    while(1);
  }

  if(!ina219.begin())
  {
    Serial.println("INA219 tidak ditemukan");
  }

  trackerServo.setPeriodHertz(50);
  trackerServo.attach(servoPin,500,2500);
  trackerServo.write(servoPos);

  WiFi.begin(ssid,password);

  Serial.print("Connecting");

  int timeout = 0;
  while(WiFi.status()!=WL_CONNECTED)
  {
    delay(500);
    Serial.print(".");
    timeout++;
    
    if(timeout > 30)
    {
      Serial.println("\nGagal konek! Coba lagi...");
      WiFi.disconnect(true,true);
      delay(1000);
      WiFi.begin(ssid,password);
      timeout = 0;
    }
  }

  Serial.println();
  Serial.println("WiFi Connected!");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());
  Serial.print("Coba buka: http://");
  Serial.println(WiFi.localIP());
  Serial.println(" di browser!");

  server.on("/", handleRoot);
  server.on("/data", handleData);

  server.begin();

  Serial.println("Web Server Started!");

  display.clearDisplay();
  display.display();
}

// =====================================================
// LOOP
// =====================================================
void loop()
{
  server.handleClient();

  int leftValue = readLDR(ldrLeftPin);
  int rightValue = readLDR(ldrRightPin);

  int diff = leftValue - rightValue;

  if(millis() - lastMove >= moveInterval)
  {
    int step = map(abs(diff),0,4095,1,5);

    if(diff > deadBand)
    {
        servoPos += step;
    }
    else if(diff < -deadBand)
    {
        servoPos -= step;
    }

    servoPos = constrain(
      servoPos,
      SERVO_MIN,
      SERVO_MAX
    );

    trackerServo.write(servoPos);

    lastMove = millis();
  }

  float voltage = ina219.getBusVoltage_V();
  float current = ina219.getCurrent_mA();
  float power = voltage * current / 1000.0;

  gLeft = leftValue;
  gRight = rightValue;
  gServo = servoPos;

  gVoltage = voltage;
  gCurrent = current;
  gPower = power;

  display.clearDisplay();

  display.setTextSize(1);
  display.setTextColor(WHITE);

  display.setCursor(0,0);
  display.println("SOLAR TRACKER");

  display.setCursor(0,12);
  display.print("LDR L: ");
  display.println(leftValue);

  display.setCursor(0,22);
  display.print("LDR R: ");
  display.println(rightValue);

  display.setCursor(0,32);
  display.print("Servo: ");
  display.println(servoPos);

  display.setCursor(0,42);
  display.print("V:");
  display.print(voltage,2);

  display.setCursor(70,42);
  display.print("I:");
  display.print(current,0);

  display.setCursor(0,54);
  display.print("P:");
  display.print(power,3);

  display.display();

  delay(20);
}
